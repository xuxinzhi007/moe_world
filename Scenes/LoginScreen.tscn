[node name="PasswordLabel" type="Label" parent="LoginPanel/VBoxContainer/FormContainer"]
layout_mode = 2
text = "密码"

[node name="PasswordInput" type="LineEdit" parent="LoginPanel/VBoxContainer/FormContainer"]
layout_mode = 2
placeholder_text = "请输入密码"
secret = true

[node name="LoginButton" type="Button" parent="LoginPanel/VBoxContainer/FormContainer"]
layout_mode = 2
text = "登录"
