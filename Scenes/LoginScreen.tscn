[gd_scene load_steps=3 format=3 uid="uid://loginscreen"]

[ext_resource type="Script" uid="uid://loginscript" path="res://Scripts/login_screen.gd" id="1_login"]
[ext_resource type="Script" uid="uid://authscript" path="res://Scripts/auth_service.gd" id="2_auth"]

[node name="LoginScreen" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
